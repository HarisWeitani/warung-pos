<?xml version="1.0" encoding="utf-8"?>
<!-- DEFECT-015: declares the app's supported per-app languages so this shows up in Android
     Settings > Apps > Warung POS > Language (in addition to the in-app Language screen, which
     calls LocaleManager.setApplicationLocales() directly — see LocaleHelper.kt). Must list every
     locale a values-*/ resource qualifier exists for. -->
